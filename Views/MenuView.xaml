<Window x:Class="AzureFable.Views.MenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Azure Fable"
        Height="600"
        Width="1000">

    <Grid Background="#0a0a2e">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBlock Text="Azure Fable"
                       FontSize="48"
                       FontWeight="Bold"
                       Foreground="#5bc8f5"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,60"/>

            <Button Content="Нова гра"
                    Command="{Binding StartGameCommand}"
                    Width="200"
                    Height="50"
                    FontSize="18"
                    Margin="0,0,0,20"
                    Background="#1a1a4e"
                    Foreground="White"
                    BorderBrush="#5bc8f5"/>

            <Button Content="Вихід"
                    Command="{Binding ExitCommand}"
                    Width="200"
                    Height="50"
                    FontSize="18"
                    Background="#1a1a4e"
                    Foreground="White"
                    BorderBrush="#5bc8f5"/>

        </StackPanel>

    </Grid>
</Window>